{
  "name": "createcrafts-launcher",
  "productName": "CreateCrafts Launcher",
  "version": "1.0.1",
  "description": "CreateCrafts Launcher — Tauri 2, Minecraft 1.21.1, NeoForge.",
  "private": true,
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/rename-installer.ps1",
    "dev:vite": "vite --port 1420",
    "build:vite": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prep:brand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-branding.ps1",
    "embed:mods-key": "node scripts/embed-mods-api-key.cjs",
    "embed:mods-key:stdin": "node scripts/embed-mods-api-key.cjs --stdin",
    "test:mods-signature": "node --test ./test/launcherModsManifestSignature.test.cjs"
  },
  "keywords": [],
  "author": {
    "name": "Bl4ck3d",
    "email": "igorturos09@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
