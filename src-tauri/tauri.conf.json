{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CreateCrafts-Launcher",
  "version": "1.0.1",
  "identifier": "pl.createcrafts.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CreateCrafts Launcher",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb"],
    "publisher": "Bl4ck3d",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../branding/servers.dat": "resources/servers.dat",
      "../branding/launcher-mods-key.enc": "resources/launcher-mods-key.enc",
      "jre21": "resources/jre21"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
